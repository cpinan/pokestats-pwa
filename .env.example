# PokéStats Calculator — Environment Variables
# Copy this file to .env and fill in values. NEVER commit .env to git.
#
# Current API: PokeAPI (https://pokeapi.co) — public, free, no key needed.
#
# To add a backend proxy:
#   1. Set API_BASE_URL to your proxy endpoint.
#   2. Update js/pokemon.js → const API_BASE_URL
#   3. Your proxy forwards to https://pokeapi.co/api/v2
#      Add any auth headers server-side — never in client JS.

# Backend proxy URL (optional)
API_BASE_URL=

# CORS proxy fallback (default: https://corsproxy.io/?)
CORS_PROXY_URL=
